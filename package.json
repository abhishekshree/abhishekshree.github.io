{
  "name": "tailwind-nextjs-starter-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "cross-env SOCKET=true node ./scripts/next-remote-watch.js ./data",
    "dev": "next dev",
    "build": "node ./scripts/generate-sitemap && next build",
    "serve": "next start",
    "analyze": "env ANALYZE=true next build",
    "export": "next build && touch out/.nojekyll",
    "build-ssg": "next build && touch out/.nojekyll",
    "deploy": "gh-pages -d out -t true"
  },
  "dependencies": {
    "@mapbox/rehype-prism": "^0.9.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "gray-matter": "^4.0.2",
    "image-size": "0.9.3",
    "next": "^16.2.10",
    "next-mdx-remote-client": "^2.1.11",
    "next-seo": "^4.29.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "1.2.1",
    "rehype-code-titles": "^1.2.1",
    "rehype-katex": "^7.0.1",
    "remark-autolink-headings": "^7.0.1",
    "remark-math": "^6.0.0",
    "remark-slug": "^7.0.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@svgr/webpack": "^5.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.17.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "globby": "11.0.1",
    "husky": "^4.3.7",
    "lint-staged": "^10.5.3",
    "next-remote-watch": "^0.3.0",
    "prettier": "2.2.1",
    "rehype": "11.0.0",
    "remark-frontmatter": "3.0.0",
    "remark-parse": "9.0.0",
    "remark-stringify": "9.0.0",
    "socket.io": "^4.4.0",
    "socket.io-client": "^4.4.0",
    "unified": "9.2.0",
    "unist-util-visit": "2.0.3"

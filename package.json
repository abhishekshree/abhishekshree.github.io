{
  "name": "tailwind-nextjs-starter-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/generate-rss.mjs && node ./scripts/generate-sitemap && next build",
    "serve": "next start",
    "analyze": "env ANALYZE=true next build",
    "export": "next build && touch out/.nojekyll",
    "build-ssg": "next build && touch out/.nojekyll",
    "deploy": "gh-pages -d out -t true"
  },
  "dependencies": {
    "@mapbox/rehype-prism": "^0.9.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@waline/client": "^3.15.2",
    "feed": "^6.0.0",
    "gray-matter": "^4.0.2",
    "image-size": "0.9.3",
    "next": "^16.2.10",
    "next-mdx-remote-client": "^2.1.11",
    "next-themes": "^0.4.6",
    "postcss": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "1.2.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-code-titles": "^1.2.1",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.3.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globby": "11.0.1",
    "prettier": "^3.2.0"
  }
}
